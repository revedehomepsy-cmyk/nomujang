# PostgreSQL 연결 문자열 (Neon, Supabase, Vercel Postgres 등)
# 예: postgresql://user:pass@host:5432/dbname?sslmode=require
DATABASE_URL=""

# 임의의 긴 랜덤 문자열 (예: openssl rand -base64 32 결과)
NEXTAUTH_SECRET="change-me-in-production"

# 배포된 도메인 (Vercel 배포 후 받은 URL)
# 로컬 개발: http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"

# 시드 endpoint 보호용 비밀키. 배포 후 한 번만 사용.
SEED_SECRET=""

# 세무사 메일 발송용 SMTP (선택)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="nomujang@example.com"
